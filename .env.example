# ============================================================
# AI PROMPT OPTIMIZATION PLATFORM — Environment Configuration
# Copy this file to .env.local and fill in your values
# ============================================================

# --- App ---
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="AI Prompt Optimizer"

# --- Database (PostgreSQL + pgvector) ---
DATABASE_URL="postgresql://postgres:password@localhost:5432/Tokens?schema=public"
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# --- Redis ---
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_ORG_ID=org-...
OPENAI_DEFAULT_MODEL=gpt-4o
OPENAI_FALLBACK_MODEL=gpt-4o-mini

# --- Anthropic (multi-model support) ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_DEFAULT_MODEL=claude-3-5-sonnet-20241022

# --- Gemini (multi-model support) ---
GEMINI_API_KEY=AIza...
GEMINI_DEFAULT_MODEL=gemini-1.5-pro

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# --- BullMQ ---
BULLMQ_CONCURRENCY=5
BULLMQ_MAX_RETRIES=3

# --- Observability ---
OTEL_SERVICE_NAME=ai-prompt-optimizer
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
LOG_LEVEL=info

# --- Semantic Cache ---
SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.92
SEMANTIC_CACHE_TTL_SECONDS=3600

# --- Security ---
NEXTAUTH_SECRET=your-secret-here-min-32-chars
NEXTAUTH_URL=http://localhost:3000
API_SECRET_KEY=your-api-secret-key

# --- Development email/password login (NODE_ENV=development only; no OAuth keys required) ---
# Defaults work out of the box for local UI work; change in production-like environments.
DEV_LOGIN_EMAIL=sachin@moontechnolabs.com
DEV_LOGIN_PASSWORD=123456
